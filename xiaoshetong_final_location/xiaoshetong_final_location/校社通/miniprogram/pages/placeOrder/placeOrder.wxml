<scroll-view class="page" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="page-inner">
    <view class="top-card">
      <view>
        <text class="top-title">{{userRole === 'demander' ? '发起新任务' : '接单大厅'}}</text>
        <text class="top-desc">{{userRole === 'demander' ? '身份：需求方（去发布任务）' : '身份：跑腿员（去赚取佣金）'}}</text>
      </view>
      <view class="top-actions">
        <view class="role-tag">{{userRole === 'demander' ? '需求方' : '跑腿员'}}</view>
        <button class="switch-btn" bindtap="switchRole">切换身份</button>
      </view>
    </view>

    <block wx:if="{{userRole === 'demander'}}">
      <view class="form-card">
        <text class="section-title">填写任务信息</text>
        <text class="section-desc">精简为 5 个高频功能：代取快递、代拿外卖、代买餐饮、代签到、代排队。</text>

        <view class="service-chips">
          <block wx:for="{{serviceCards}}" wx:key="key" wx:for-item="item" wx:for-index="index">
            <view class="service-chip {{serviceTypeIndex === index ? 'active' : ''}}" bindtap="selectService" data-index="{{index}}">
              <text class="chip-title">{{item.title}}</text>
            </view>
          </block>
        </view>

        <view class="field">
          <text class="label">当前已选</text>
          <picker mode="selector" range="{{serviceTypes}}" value="{{serviceTypeIndex}}" bindchange="bindServiceTypeChange">
            <view class="picker">{{serviceTypes[serviceTypeIndex]}}</view>
          </picker>
          <text class="hint">当前类型可用免单券：{{freeCouponCount}} 张</text>
        </view>

        <view class="field">
          <text class="label">取件信息</text>
          <input class="input" placeholder="示例：5-302 / 宿管处快递柜" value="{{pickupCode}}" data-field="pickupCode" bindinput="bindInput" />
        </view>

        <view class="field">
          <text class="label">送达地址 (当前校区: {{currentSchool}} · {{currentCampus}})</text>
          <view class="location-input-wrap">
            <input class="input" style="flex: 1; border: none; background: transparent; padding: 0;" placeholder="点击右侧定位或选择下方建筑" value="{{destination}}" disabled />
            <view class="location-icon-btn" bindtap="chooseLocation">📍地图选点</view>
          </view>
          <view class="coord-info" wx:if="{{destinationLat}}">
            <text class="coord-text">📌 坐标: {{destinationLat}}, {{destinationLng}}</text>
          </view>
          <input class="input" style="margin-top: 16rpx;" placeholder="补充详细门牌号，如：3单元302室" value="{{detailAddress}}" data-field="detailAddress" bindinput="bindInput" />

          <view class="building-section" wx:if="{{campusBuildings.length > 0}}">
            <text class="building-label">🏫 校内常用地点（点击自动定位）：</text>
            <view class="building-chips">
              <block wx:for="{{campusBuildings}}" wx:key="*this">
                <view class="building-chip {{item.indexOf('宿舍') > -1 || item.indexOf('公寓') > -1 || item.indexOf('舍') > -1 ? 'dorm' : ''}}" bindtap="selectBuilding" data-building="{{item}}">
                  <text wx:if="{{item.indexOf('宿舍') > -1 || item.indexOf('公寓') > -1 || item.indexOf('舍') > -1}}">🏠 </text>{{item}}
                </view>
              </block>
            </view>
          </view>

          <view class="history-tags" wx:if="{{addressHistory.length > 0}}">
            <text class="history-label">🕐 历史地址：</text>
            <view class="history-chip" wx:for="{{addressHistory}}" wx:key="*this" bindtap="selectHistoryAddress" data-address="{{item}}">{{item}}</view>
          </view>
        </view>

        <view class="field-row">
          <view class="field" style="flex: 1; margin-top: 0;">
            <text class="label">联系人</text>
            <input class="input" placeholder="怎么称呼" value="{{contactName}}" data-field="contactName" bindinput="bindInput" />
          </view>
          <view class="field" style="flex: 1; margin-top: 0;">
            <text class="label">联系电话</text>
            <input class="input" type="number" placeholder="手机长号" value="{{contactPhone}}" data-field="contactPhone" bindinput="bindInput" />
          </view>
        </view>

        <view class="field">
          <text class="label">悬赏金额 (跑腿费)</text>
          <input class="input" type="digit" placeholder="例如 12.50" value="{{amount}}" data-field="amount" bindinput="bindInput" />
          <text class="hint">合规提示：平台仅作信息撮合，实际费用请在送达后当面结算。</text>
        </view>

        <view class="field">
          <text class="label">任务备注</text>
          <textarea class="textarea" placeholder="如：提前打电话、不要放地上" value="{{remark}}" data-field="remark" bindinput="bindInput" />
        </view>

        <button class="primary-btn" bindtap="submitOrder">确认发布 (免押金)</button>
      </view>
    </block>

    <block wx:else>
      <view class="hall-card">
        <view class="hall-head">
          <view>
            <text class="section-title">待接订单 (当前校区)</text>
            <text class="section-desc">同校区用户下单后，你会在这里看到待接订单。</text>
          </view>
          <view class="count-badge">{{pendingOrders.length}} 单</view>
        </view>

        <block wx:if="{{pendingOrders.length}}">
          <block wx:for="{{pendingOrders}}" wx:key="id" wx:for-item="item">
            <view class="hall-order">
              <view class="hall-top">
                <text class="hall-title">{{item.serviceTypeName}}</text>
                <view class="state-badge">待接单</view>
              </view>
              <text class="hall-line" style="color: #ea580c;">📍 {{item.school}} - {{item.campus}}</text>
              <text class="hall-line">发布者：{{item.demanderName}}</text>
              <text class="hall-line">取件信息：{{item.pickupCode}}</text>
              <text class="hall-line">送达地址：{{item.destination}}</text>
              <text class="hall-line">订单金额：¥{{item.amount}}</text>
              <button class="primary-btn mini-btn" data-id="{{item.id}}" bindtap="acceptHallOrder">立即接单</button>
            </view>
          </block>
        </block>

        <view class="empty-card" wx:else>
          <text class="empty-title">暂时没有待接订单</text>
          <text class="empty-desc">需求方下单后，这里会自动刷新出新的待接订单。</text>
        </view>
      </view>

      <view class="hall-card" wx:if="{{myOrders.length}}">
        <view class="hall-head">
          <view>
            <text class="section-title">我已接单</text>
          </view>
          <text class="section-link" bindtap="goOrders">去处理订单</text>
        </view>

        <block wx:for="{{myOrders}}" wx:key="id" wx:for-item="item">
          <view class="hall-order compact">
            <view class="hall-top">
              <text class="hall-title">{{item.serviceTypeName}}</text>
              <view class="state-badge">{{item.stateText}}</view>
            </view>
            <text class="hall-line">送达地址：{{item.destination}}</text>
          </view>
        </block>
      </view>
    </block>

  </view>
</scroll-view>